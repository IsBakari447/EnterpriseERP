<div class="page-header">
    <div>
        <h1>@L("Title")</h1>
        <p>@L("Subtitle")</p>
    </div>

    <a href="/Admin/Index" class="btn-secondary">
        &larr; @L("BackAdmin")
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert-danger">@TempData["Error"]</div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div>
            <h3>@ViewBag.TotalUsers</h3>
            <p>@L("TotalUsers")</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div>
            <h3>@ViewBag.ActiveUsers</h3>
            <p>@L("ActiveUsers")</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">⛔</div>
        <div>
            <h3>@ViewBag.InactiveUsers</h3>
            <p>@L("InactiveUsers")</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">⏳</div>
        <div>
            <h3>@ViewBag.PendingUsers</h3>
            <p>@L("PendingUsers")</p>
        </div>
    </div>
</div>

<div class="panel">
    <h2>@L("Filters")</h2>

    <form method="get" action="/Users/Index" class="search-box" style="max-width:100%; margin-bottom:20px;">
        <input type="text"
               name="search"
               placeholder="@L("SearchPlaceholder")"
               value="@ViewBag.Search" />

        <select name="role">
            <option value="">@L("AllRoles")</option>
            <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin</option>
            <option value="Manager" selected="@(ViewBag.Role == "Manager")">Manager</option>
            <option value="Employee" selected="@(ViewBag.Role == "Employee")">Employee</option>
        </select>

        <select name="status">
            <option value="">@L("AllStatuses")</option>
            <option value="active" selected="@(ViewBag.Status == "active")">@L("ActiveUsers")</option>
            <option value="inactive" selected="@(ViewBag.Status == "inactive")">@L("InactiveUsers")</option>
            <option value="pending" selected="@(ViewBag.Status == "pending")">@L("PendingUsers")</option>
        </select>

        <button type="submit" class="btn-primary">@L("Filter")</button>

        <button type="button"
                class="btn-secondary"
                onclick="window.location.href='@Url.Action("Index", "Users")'">
            @L("Reset")
        </button>
    </form>
</div>

<div class="panel">
    <div class="page-header" style="margin-bottom:15px;">
        <div>
            <h2>@L("UsersList")</h2>
        </div>

        <a href="/Account/Register" class="btn-primary">
            + @L("CreateUser")
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>@L("User")</th>
                    <th>@L("Role")</th>
                    <th>@L("Status")</th>
                    <th>@L("LastLogin")</th>
                    <th>IP</th>
                    <th>@L("Connections")</th>
                    <th>@L("Actions")</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong><br />
                            <small>@user.Email</small>
                        </td>

                        <td>
                            @if (user.IsSuperAdmin)
                            {
                                <strong>SuperAdmin</strong>
                            }
                            else
                            {
                                <form method="post" action="/Users/ChangeRole" style="display:flex; gap:6px;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />

                                    <select name="role">
                                        <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                        <option value="Manager" selected="@(user.Role == "Manager")">Manager</option>
                                        <option value="Employee" selected="@(user.Role == "Employee")">Employee</option>
                                    </select>

                                    <button type="submit" class="btn-secondary">OK</button>
                                </form>
                            }
                        </td>

                        <td>
                            <div>@L("Active") : @(user.IsActive ? L("Yes") : L("No"))</div>
                            <div>@L("Approved") : @(user.IsApproved ? L("Yes") : L("No"))</div>
                        </td>

                        <td>@(user.LastConnection?.ToString("dd/MM/yyyy HH:mm") ?? L("Never"))</td>
                        <td>@user.LastIPAddress</td>
                        <td>@user.LoginCount</td>

                        <td>
                            @if (!user.IsApproved)
                            {
                                <form method="post" action="/Users/Approve" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-primary">@L("Approve")</button>
                                </form>
                            }

                            @if (!user.IsSuperAdmin)
                            {
                                <form method="post" action="/Users/ToggleActive" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-danger">
                                        @(user.IsActive ? L("Disable") : L("Enable"))
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty">@L("Empty")</p>
    }
</div>
