@model EnterpriseERP.Models.Order

@{
    ViewData["Title"] = "Nouvelle commande";

    var clients = ViewBag.Clients as List<EnterpriseERP.Models.Client>;
    var products = ViewBag.Products as List<EnterpriseERP.Models.Product>;
}

<div class="page-header">

    <div>
        <h1>Nouvelle commande</h1>
        <p>Créer une nouvelle commande client</p>
    </div>

    <div>
        <a asp-controller="Orders"
           asp-action="Index"
           class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left"></i>
            Retour à la liste

        </a>
    </div>

</div>

<div class="form-card">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mb-4">
            @ViewBag.Error
        </div>
    }

    <form asp-controller="Orders"
          asp-action="Create"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="All"
             class="text-danger mb-3">
        </div>

        <!-- CLIENT -->

        <div class="form-group mb-4">

            <label class="form-label fw-bold">

                <i class="bi bi-person"></i>

                Client

            </label>

            <select name="ClientId"
                    class="form-select"
                    required>

                <option value="">
                    -- Sélectionner un client --
                </option>

                @if (clients != null)
                {
                    foreach (var client in clients)
                    {
                        <option value="@client.Id">
                            @client.FullName
                        </option>
                    }
                }

            </select>

        </div>

        <!-- PRODUIT -->

        <div class="form-group mb-4">

            <label class="form-label fw-bold">

                <i class="bi bi-box-seam"></i>

                Produit

            </label>

            <select name="ProductId"
                    class="form-select"
                    required>

                <option value="">
                    -- Sélectionner un produit --
                </option>

                @if (products != null)
                {
                    foreach (var product in products)
                    {
                        <option value="@product.Id">

                            @product.Name

                            -

                            @product.SalePrice.ToString("N2") €

                            -

                            Stock :
                            @product.Quantity

                        </option>
                    }
                }

            </select>

        </div>

        <!-- QUANTITE -->

        <div class="form-group mb-4">

            <label class="form-label fw-bold">

                <i class="bi bi-123"></i>

                Quantité

            </label>

            <input name="Quantity"
                   type="number"
                   min="1"
                   value="1"
                   class="form-control"
                   required />

        </div>

        <!-- STATUT -->

        <div class="form-group mb-5">

            <label class="form-label fw-bold">

                <i class="bi bi-check-circle"></i>

                Statut

            </label>

            <select name="Status"
                    class="form-select">

                <option value="Pending">
                    En attente
                </option>

                <option value="Confirmed">
                    Confirmée
                </option>

                <option value="Delivered">
                    Livrée
                </option>

                <option value="Cancelled">
                    Annulée
                </option>

            </select>

        </div>

        <!-- BOUTONS -->

        <div class="d-flex justify-content-between">

            <a asp-controller="Orders"
               asp-action="Index"
               class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left"></i>

                Retour

            </a>

            <button type="submit"
                    class="btn btn-primary">

                <i class="bi bi-save"></i>

                Enregistrer la commande

            </button>

        </div>

    </form>

</div>

@section Scripts{

    <partial name="_ValidationScriptsPartial" />

}