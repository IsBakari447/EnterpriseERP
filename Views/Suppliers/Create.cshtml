@model EnterpriseERP.Models.Supplier

@{
    ViewData["Title"] = "Ajouter un fournisseur";
}

<div class="page-header">
    <div>
        <h1>Ajouter un fournisseur</h1>
        <p>Créer une nouvelle fiche fournisseur</p>
    </div>

    <a href="/Suppliers/Index" class="btn-secondary">
        ← Retour
    </a>
</div>

<div class="form-card">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">@ViewBag.Error</div>
    }

    <form method="post" action="/Suppliers/Create">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Nom du fournisseur</label>
            <input name="Name" value="@Model?.Name" required />
        </div>

        <div class="form-group">
            <label>Personne de contact</label>
            <input name="ContactPerson" value="@Model?.ContactPerson" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input name="Email" type="email" value="@Model?.Email" />
        </div>

        <div class="form-group">
            <label>Téléphone</label>
            <input name="Phone" value="@Model?.Phone" />
        </div>

        <div class="form-group">
            <label>Catégorie</label>
            <input name="Category" value="@Model?.Category" placeholder="Ex: Informatique, Transport, Alimentaire..." />
        </div>

        <div class="form-group">
            <label>Adresse</label>
            <input name="Address" value="@Model?.Address" />
        </div>

        <button type="submit" class="btn-primary">
            Enregistrer
        </button>
    </form>
</div>
