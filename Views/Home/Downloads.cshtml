@{
    ViewData["Title"] = "Applications mobiles et desktop - EnterpriseERP";
}

@await Html.PartialAsync("_PublicProductStyles")

<section class="public-page">
    <div class="public-hero compact">
        <div>
            <span class="eyebrow">Applications</span>
            <h1>EnterpriseERP sur Web, Android, iOS et Windows.</h1>
            <p>Une experience adaptee aux dirigeants, commerciaux, gestionnaires de stock, equipes RH et administrateurs.</p>
        </div>
    </div>

    <div class="platform-grid">
        <article class="platform-card">
            <i class="bi bi-android2"></i>
            <h2>Android</h2>
            <p>Application complete pour gerer clients, factures, stock, dashboard mobile et Assistant AI integre.</p>
            <a class="btn btn-primary" href="/downloads/EnterpriseERP.Mobile.apk">Telecharger APK</a>
        </article>

        <article class="platform-card">
            <i class="bi bi-phone"></i>
            <h2>iOS</h2>
            <p>Version optimisee iPhone et iPad avec interface fluide, synchronisation temps reel et notifications intelligentes.</p>
            <a class="btn btn-primary" href="/downloads/EnterpriseERP.Mobile.ipa">Telecharger iOS</a>
        </article>

        <article class="platform-card">
            <i class="bi bi-windows"></i>
            <h2>Windows MAUI</h2>
            <p>Application desktop professionnelle avec acces rapide aux modules et fonctionnement hors ligne optionnel.</p>
            <a class="btn btn-primary" href="/downloads/EnterpriseERP.Mobile.msix">Telecharger MSIX</a>
        </article>
    </div>
</section>
