            demo: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Demo"))),
            contact: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Contact"))),
            login: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Login"))),
            tryFree: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("TryFree"))),
            createAccount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("CreateAccount"))),
            downloadMobile: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("DownloadMobile"))),
            badge: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Badge"))),
            heroTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("HeroTitle"))),
            heroAccent: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("HeroAccent"))),
            heroText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("HeroText"))),
            statModules: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StatModules"))),
            statAi: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StatAi"))),
            statPdf: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StatPdf"))),
            statMobile: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StatMobile"))),
            companyHealth: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("CompanyHealth"))),
            priority: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Priority"))),
            profit: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Profit"))),
            unpaidInvoices: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("UnpaidInvoices"))),
            lowStock: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("LowStock"))),
            clients: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Clients"))),
            modulesTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("ModulesTitle"))),
            modulesText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("ModulesText"))),
            crmTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("CrmTitle"))),
            crmText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("CrmText"))),
            stockTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StockTitle"))),
            stockText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StockText"))),
            invoicesTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("InvoicesTitle"))),
            invoicesText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("InvoicesText"))),
            hrTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("HrTitle"))),
            hrText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("HrText"))),
            security: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Security"))),
            securityText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("SecurityText"))),
            aiTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("AiTitle"))),
            aiText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("AiText"))),
            aiBadge: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("AiBadge"))),
            aiSectionTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("AiSectionTitle"))),
            aiSectionText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("AiSectionText"))),
            tryAi: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("TryAi"))),
            seeDemo: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("SeeDemo"))),
            chat1: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Chat1"))),
            chat2: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Chat2"))),
            chat3: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Chat3"))),
