            offersTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("OffersTitle"))),
            offersText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("OffersText"))),
            free: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Free"))),
            starterText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("StarterText"))),
            toDefine: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("ToDefine"))),
            businessText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("BusinessText"))),
