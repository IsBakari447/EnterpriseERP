            enterpriseText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("EnterpriseText"))),
            footerText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("FooterText"))),
            product: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Product"))),
            access: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Access"))),
            support: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Support"))),
            rights: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Rights"))),
            powered: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("Powered")))
        };

        const set = (selector, value) => {
            const node = document.querySelector(selector);
            if (node) node.textContent = value;
        };

        document.documentElement.lang = "@T.Lang";
        document.title = text.title;

        const navLinks = document.querySelectorAll(".nav-links a");
        [text.features, text.modules, text.downloads, text.pricing, text.demo, text.contact]
            .forEach((value, index) => {
                if (navLinks[index]) navLinks[index].textContent = value;
            });

        const languageSelect = document.querySelector(".landing-lang-form select");
        if (languageSelect) {
            const current = "@T.Lang";
            const labels = { fr: "FR", en: "EN", sv: "SV", es: "ES", de: "DE" };
            Object.entries(labels).forEach(([value, label]) => {
                if (!languageSelect.querySelector(`option[value="${value}"]`)) {
                    languageSelect.add(new Option(label, value));
                }
            });
            languageSelect.value = current;
        }

        const actionButtons = document.querySelectorAll(".nav-actions .btn");
        if (actionButtons[0]) actionButtons[0].textContent = text.login;
        if (actionButtons[1]) actionButtons[1].textContent = text.tryFree;

        set(".hero .badge", text.badge);
        const heroTitle = document.querySelector(".hero h1");
        if (heroTitle) {
            heroTitle.textContent = "";
            heroTitle.append(document.createTextNode(`${text.heroTitle} `));
            const accent = document.createElement("span");
            accent.textContent = text.heroAccent;
            heroTitle.append(accent);
        }
        set(".hero p", text.heroText);

        const heroButtons = document.querySelectorAll(".hero-buttons .btn");
        if (heroButtons[0]) heroButtons[0].textContent = text.createAccount;
        if (heroButtons[1]) heroButtons[1].textContent = text.login;
        if (heroButtons[2]) heroButtons[2].textContent = text.downloadMobile;

        const stats = document.querySelectorAll(".stats .stat span");
        [text.statModules, text.statAi, text.statPdf, text.statMobile].forEach((value, index) => {
            if (stats[index]) stats[index].textContent = value;
        });

        const dashParagraphs = document.querySelectorAll(".dash-card p");
        if (dashParagraphs[0]) dashParagraphs[0].textContent = text.companyHealth;
        if (dashParagraphs[1]) dashParagraphs[1].textContent = text.priority;

        const minis = document.querySelectorAll(".dash-grid .mini");
        [text.profit, text.unpaidInvoices, text.lowStock, text.clients].forEach((value, index) => {
            const mini = minis[index];
            if (!mini) return;
            const strong = mini.querySelector("strong");
            mini.textContent = value;
            if (strong) mini.append(strong);
        });

        const sections = document.querySelectorAll(".section");
        if (sections[0]) {
            set("#modules .section-header h2", text.modulesTitle);
            set("#modules .section-header p", text.modulesText);
            const moduleCards = sections[0].querySelectorAll(".card");
            [
                [text.crmTitle, text.crmText],
                [text.stockTitle, text.stockText],
                [text.invoicesTitle, text.invoicesText],
                [text.hrTitle, text.hrText],
                [text.security, text.securityText],
                [text.aiTitle, text.aiText]
            ].forEach(([title, body], index) => {
                if (moduleCards[index]) {
                    const heading = moduleCards[index].querySelector("h3");
                    const paragraph = moduleCards[index].querySelector("p");
                    if (heading) heading.textContent = title;
                    if (paragraph) paragraph.textContent = body;
                }
            });
        }

        if (sections[1]) {
            const aiButtons = sections[1].querySelectorAll(".hero-buttons .btn");
            set(".section:nth-of-type(3) .badge", text.aiBadge);
            set(".section:nth-of-type(3) h2", text.aiSectionTitle);
            set(".section:nth-of-type(3) p", text.aiSectionText);
            if (aiButtons[0]) aiButtons[0].textContent = text.tryAi;
            if (aiButtons[1]) aiButtons[1].textContent = text.seeDemo;
            const messages = sections[1].querySelectorAll(".msg");
            [text.chat1, text.chat2, text.chat3, text.chat4].forEach((value, index) => {
                if (messages[index]) messages[index].textContent = value;
            });
        }

        if (sections[2]) {
            const downloadCards = sections[2].querySelectorAll(".card");
            const downloadButtons = sections[2].querySelectorAll(".btn");
            set(".download .badge", text.mobileBadge);
            set(".download h2", text.mobileTitle);
            set(".download .split > div > p", text.mobileText);
            if (downloadCards[0]?.querySelector("p")) downloadCards[0].querySelector("p").textContent = text.androidText;
            if (downloadCards[1]?.querySelector("p")) downloadCards[1].querySelector("p").textContent = text.iosText;
            if (downloadCards[2]?.querySelector("p")) downloadCards[2].querySelector("p").textContent = text.windowsText;
            downloadButtons.forEach(button => button.textContent = text.download);
        }

        if (sections[3]) {
            set(".section:nth-of-type(5) .section-header h2", text.whyTitle);
            set(".section:nth-of-type(5) .section-header p", text.whyText);
            const whyCards = sections[3].querySelectorAll(".card");
            [[text.fast, text.fastText], [text.cloudReady, text.cloudText], [text.decision, text.decisionText]]
                .forEach(([title, body], index) => {
                    if (whyCards[index]) {
                        const heading = whyCards[index].querySelector("h3");
                        const paragraph = whyCards[index].querySelector("p");
                        if (heading) heading.textContent = title;
                        if (paragraph) paragraph.textContent = body;
                    }
                });
        }

        if (sections[4]) {
            set(".section:nth-of-type(6) .section-header h2", text.offersTitle);
            set(".section:nth-of-type(6) .section-header p", text.offersText);
            const prices = sections[4].querySelectorAll(".price");
            [[text.free, text.starterText], [text.toDefine, text.businessText], [text.quoteOnly, text.enterpriseText]]
                .forEach(([price, body], index) => {
                    if (prices[index]) {
                        const heading = prices[index].querySelector("h4");
                        const paragraph = prices[index].querySelector("p");
                        if (heading) heading.textContent = price;
                        if (paragraph) paragraph.textContent = body;
                    }
                });
        }

        const footerColumns = document.querySelectorAll(".footer > div");
        if (footerColumns[0]?.querySelector("p")) footerColumns[0].querySelector("p").textContent = text.footerText;
        if (footerColumns[1]?.querySelector("h4")) footerColumns[1].querySelector("h4").textContent = text.product;
        if (footerColumns[2]?.querySelector("h4")) footerColumns[2].querySelector("h4").textContent = text.access;
        if (footerColumns[3]?.querySelector("h4")) footerColumns[3].querySelector("h4").textContent = text.contact;

        const footerProductLinks = footerColumns[1]?.querySelectorAll("a") ?? [];
        [text.features, text.downloads, text.pricing].forEach((value, index) => {
            if (footerProductLinks[index]) footerProductLinks[index].textContent = value;
        });
        const footerAccessLinks = footerColumns[2]?.querySelectorAll("a") ?? [];
        [text.login, text.createAccount, text.demo].forEach((value, index) => {
            if (footerAccessLinks[index]) footerAccessLinks[index].textContent = value;
        });
        const supportLink = footerColumns[3]?.querySelectorAll("a")[1];
        if (supportLink) supportLink.textContent = text.support;

        const bottom = document.querySelectorAll(".bottom div");
        if (bottom[0]) bottom[0].textContent = `© ${new Date().getFullYear()} EnterpriseERP. ${text.rights}`;
        if (bottom[1]) bottom[1].textContent = `Version 1.0 · ${text.powered}`;
    })();
</script>
</body>
</html>
