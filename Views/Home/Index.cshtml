<!DOCTYPE html>
<html lang="@T.Lang">
<head>
    <meta charset="utf-8" />
    <title>@L("Title")</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" type="image/png" href="~/img/enterpriseerp-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        * { box-sizing: border-box; }

        :root {
            --bg: #020617;
            --panel: #0f172a;
            --panel2: #111827;
            --border: #334155;
            --text: #f8fafc;
            --muted: #94a3b8;
            --purple: #8b5cf6;
            --purple2: #7c3aed;
            --blue: #2563eb;
            --green: #22c55e;
        }

        html {
            scroll-behavior: smooth;
            background: #020617 !important;
            color-scheme: dark;
        }

        body {
            margin: 0;
            font-family: "Segoe UI", Arial, sans-serif;
            background: var(--bg) !important;
            color: var(--text) !important;
            overflow-x: hidden;
            forced-color-adjust: none;
        }

        a { text-decoration: none; color: inherit; }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 18px 7%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            background: rgba(2, 6, 23, .86);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(51,65,85,.55);
        }

        .brand {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-size: 28px;
            font-weight: 900;
            white-space: nowrap;
        }

        .brand img {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            object-fit: cover;
            background: white;
        }

        .brand span { color: var(--purple); }

        .nav-links {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .nav-links a {
            padding: 10px 14px;
            border-radius: 999px;
            color: #cbd5e1;
            font-weight: 600;
            font-size: 14px;
        }

        .nav-links a:hover {
            background: #111827;
            color: white;
        }

        .nav-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            white-space: nowrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 13px 18px;
            border-radius: 14px;
            font-weight: 800;
            border: 1px solid var(--border);
            color: white;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--purple2), var(--purple));
            border-color: transparent;
        }

        .btn-dark { background: #111827; }

        .hero {
            padding: 95px 7% 80px;
            background:
                radial-gradient(circle at top left, rgba(124,58,237,.30), transparent 34%),
                radial-gradient(circle at top right, rgba(37,99,235,.28), transparent 30%),
                linear-gradient(135deg, #020617, #0b1228);
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.05fr .95fr;
            align-items: center;
            gap: 70px;
        }

        .badge {
            display: inline-block;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(124,58,237,.22);
            color: #c4b5fd;
            font-weight: 900;
            margin-bottom: 26px;
        }

        h1 {
            font-size: clamp(44px, 5vw, 82px);
            line-height: 1.03;
            margin: 0;
            letter-spacing: -2px;
        }

        h1 span { color: #a78bfa; }

        .hero p {
            margin-top: 26px;
            color: #cbd5e1;
            font-size: 20px;
            line-height: 1.8;
            max-width: 780px;
        }

        .hero-buttons {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-top: 34px;
        }

        .stats {
            margin-top: 44px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
        }

        .stat {
            background: rgba(15,23,42,.8);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
        }

        .stat strong {
            font-size: 26px;
            display: block;
            color: white;
        }

        .stat span {
            color: var(--muted);
            font-size: 14px;
        }

        .mockup {
            border: 1px solid var(--border);
            border-radius: 32px;
            background: rgba(15,23,42,.78);
            padding: 24px;
            box-shadow: 0 35px 120px rgba(0,0,0,.5);
        }

        .mockup-top {
            display: flex;
            gap: 8px;
            margin-bottom: 18px;
        }

        .dot {
            width: 12px;
            height: 12px;
            border-radius: 99px;
            background: #64748b;
        }

        .dash-card {
            background: #111827;
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 24px;
            margin-bottom: 16px;
        }

        .dash-card h3 {
            margin: 0 0 14px;
            color: #a78bfa;
            font-size: 26px;
        }

        .dash-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }

        .mini {
            background: #0f172a;
            border: 1px solid #273449;
            border-radius: 16px;
            padding: 16px;
        }

        .mini strong {
            display: block;
            font-size: 22px;
            margin-top: 6px;
        }

        .section {
            padding: 90px 7%;
        }

        .section-header {
            max-width: 850px;
            margin-bottom: 42px;
        }

        .section h2 {
            font-size: clamp(34px, 3.5vw, 52px);
            margin: 0 0 16px;
            letter-spacing: -1px;
        }

        .section p {
            color: var(--muted);
            line-height: 1.75;
            font-size: 18px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        .mobile-download-cards {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .card {
            background: #0f172a;
            border: 1px solid #1e293b;
            border-radius: 24px;
            padding: 26px;
            min-height: 190px;
        }

        .card:hover {
            border-color: var(--purple);
            transform: translateY(-3px);
            transition: .2s;
        }

        .icon {
            width: 48px;
            height: 48px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: rgba(124,58,237,.22);
            margin-bottom: 18px;
            font-size: 24px;
        }

        .card h3 {
            margin: 0 0 10px;
            font-size: 22px;
        }

        .split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 44px;
            align-items: center;
        }

        .ai-box {
            background:
                radial-gradient(circle at top right, rgba(124,58,237,.22), transparent 40%),
                #0f172a;
            border: 1px solid var(--border);
            border-radius: 30px;
            padding: 34px;
        }

        .chat {
            display: grid;
            gap: 14px;
        }

        .msg {
            padding: 16px;
            border-radius: 18px;
            background: #111827;
            border: 1px solid #334155;
            color: #e5e7eb;
        }

        .msg.ai {
            border-color: rgba(139,92,246,.75);
        }

        .download {
            background: linear-gradient(135deg, #111827, #1e1b4b);
            border-top: 1px solid #1e293b;
            border-bottom: 1px solid #1e293b;
        }

        .pricing {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        .price {
            background: #0f172a;
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 30px;
        }

        .price.featured {
            border-color: var(--purple);
            box-shadow: 0 0 0 1px rgba(139,92,246,.3);
        }

        .price h3 { font-size: 26px; }
        .price h4 { font-size: 34px; margin: 12px 0; }

        .footer {
            padding: 50px 7%;
            border-top: 1px solid #1e293b;
            display: grid;
            grid-template-columns: 1.5fr repeat(3, 1fr);
            gap: 28px;
            color: var(--muted);
        }

        .footer h4 {
            color: white;
            margin-top: 0;
        }

        .footer a {
            display: block;
            margin: 10px 0;
            color: #cbd5e1;
        }

        .bottom {
            padding: 20px 7%;
            border-top: 1px solid #1e293b;
            color: #64748b;
            display: flex;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
        }

        @@media(max-width: 1100px) {
            .hero-grid, .split { grid-template-columns: 1fr; }
            .cards, .pricing { grid-template-columns: repeat(2, 1fr); }
            .mobile-download-cards { grid-template-columns: 1fr; }
            .stats { grid-template-columns: repeat(2, 1fr); }
            .navbar { align-items: flex-start; flex-direction: column; }
            .nav-actions { flex-wrap: wrap; }
        }

        @@media(max-width: 720px) {
            .cards, .pricing, .stats, .dash-grid, .footer { grid-template-columns: 1fr; }
            .hero, .section { padding-left: 24px; padding-right: 24px; }
            .navbar { padding-left: 24px; padding-right: 24px; }
        }

        /* Production safety: keep the public page readable even when browser
           contrast extensions or stale cached CSS try to flatten the theme. */
        html,
        body,
        body.landing-page {
            background: #020617 !important;
            color: #f8fafc !important;
            forced-color-adjust: none !important;
        }

        .navbar {
            background: rgba(2, 6, 23, .94) !important;
        }

        .hero {
            background:
                radial-gradient(circle at top left, rgba(124,58,237,.32), transparent 34%),
                radial-gradient(circle at top right, rgba(37,99,235,.30), transparent 30%),
                linear-gradient(135deg, #020617, #0b1228) !important;
        }

        .mockup,
        .stat,
        .card,
        .price,
        .dash-card,
        .mini,
        .ai-box,
        .msg {
            background-color: #0f172a !important;
            color: #f8fafc !important;
            border-color: #334155 !important;
        }

        h1,
        h2,
        h3,
        h4,
        .brand,
        .stat strong,
        .mini strong,
        .footer h4 {
            color: #ffffff !important;
        }

        p,
        .nav-links a,
        .section p,
        .footer,
        .bottom,
        .card p,
        .price p,
        .stat span {
            color: #cbd5e1 !important;
        }
    </style>
</head>

