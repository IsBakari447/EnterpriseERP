<style>
    .public-page {
        max-width: 1220px;
        margin: 0 auto;
        padding: 8px 0 42px;
    }

    .public-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(280px, .6fr);
        gap: 24px;
        align-items: stretch;
        margin-bottom: 28px;
    }

    .public-hero.compact {
        grid-template-columns: 1fr;
    }

    .public-hero > div,
    .hero-proof,
    .feature-card,
    .price-card,
    .platform-card,
    .section-block,
    .video-placeholder {
        border: 1px solid var(--border);
        border-radius: 20px;
        background:
            linear-gradient(145deg, rgba(30, 41, 59, .92), rgba(15, 23, 42, .86)),
            var(--panel);
        box-shadow: 0 16px 35px var(--shadow);
    }

    .public-hero > div:first-child,
    .hero-proof,
    .feature-card,
    .price-card,
    .platform-card,
    .section-block {
        padding: 26px;
    }

    .public-hero > div:first-child {
        padding: 34px;
    }

    .public-hero h1 {
        max-width: 900px;
        color: var(--text);
        font-size: clamp(34px, 4vw, 56px);
        line-height: 1.04;
        letter-spacing: 0;
        margin: 12px 0 16px;
    }

    .public-hero p,
    .section-title p,
    .feature-card p,
    .price-card p,
    .platform-card p,
    .value-grid p,
    .demo-access p,
    .support-grid p,
    .faq-list p {
        color: var(--muted);
        line-height: 1.65;
    }

    .eyebrow,
    .plan-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        min-height: 30px;
        padding: 6px 12px;
        border: 1px solid rgba(56, 189, 248, .24);
        border-radius: 999px;
        background: rgba(14, 165, 233, .10);
        color: #7dd3fc;
        font-size: 12px;
        font-weight: 900;
        line-height: 1;
        text-transform: uppercase;
    }

    .hero-proof {
        display: grid;
        align-content: end;
        gap: 12px;
        min-height: 260px;
    }

    .hero-proof strong {
        color: var(--text);
        font-size: 22px;
    }

    .hero-proof span {
        color: var(--muted);
        line-height: 1.6;
    }

    .feature-grid,
    .pricing-table,
    .platform-grid,
    .support-grid,
    .faq-grid,
    .value-grid {
        display: grid;
        gap: 18px;
    }

    .feature-grid,
    .support-grid,
    .faq-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pricing-table,
    .platform-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .value-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .feature-card h2,
    .price-card h2,
    .platform-card h2,
    .section-title h2 {
        color: var(--text);
        line-height: 1.2;
        letter-spacing: 0;
    }

    .feature-card h2,
    .platform-card h2 {
        margin: 14px 0;
    }

    .feature-icon,
    .platform-card > i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 52px;
        height: 52px;
        border: 1px solid rgba(56, 189, 248, .24);
        border-radius: 16px;
        background: rgba(2, 6, 23, .48);
        color: #38bdf8;
        font-size: 22px;
    }

    .feature-card ul,
    .price-card ul,
    .roadmap-list {
        display: grid;
        gap: 10px;
        margin: 16px 0 0;
        padding: 0;
        list-style: none;
    }

    .feature-card li,
    .price-card li,
    .roadmap-list li {
        position: relative;
        padding-left: 24px;
        color: #cbd5e1;
        line-height: 1.5;
    }

    .feature-card li::before,
    .price-card li::before,
    .roadmap-list li::before {
        content: "";
        position: absolute;
        left: 0;
        top: .62em;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: linear-gradient(135deg, #2563eb, #06b6d4);
    }

    .section-block {
        margin-top: 18px;
    }

    .section-title {
        margin-bottom: 18px;
    }

    .integration-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .integration-strip span {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 8px 13px;
        border: 1px solid rgba(148, 163, 184, .25);
        border-radius: 999px;
        color: #dbeafe;
        background: rgba(15, 23, 42, .52);
        font-weight: 800;
    }

    .value-grid > div {
        min-height: 150px;
        padding: 18px;
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 16px;
        background: rgba(2, 6, 23, .30);
    }

    .value-grid strong {
        display: block;
        color: var(--text);
        margin-bottom: 8px;
    }

    .price-card {
        display: flex;
        flex-direction: column;
        min-height: 440px;
    }

    .price-card.highlighted {
        border-color: rgba(37, 99, 235, .70);
        box-shadow: 0 22px 50px rgba(37, 99, 235, .18);
    }

    .price-card h2 {
        margin: 14px 0;
        font-size: 34px;
    }

    .price-card h2 small {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        font-size: 14px;
    }

    .price-card .btn {
        margin-top: auto;
        width: fit-content;
    }

    .platform-card {
        min-height: 300px;
    }

    .demo-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, .85fr);
        gap: 18px;
    }

    .video-placeholder {
        display: grid;
        place-items: center;
        min-height: 420px;
        padding: 28px;
        text-align: center;
    }

    .video-placeholder i {
        color: #38bdf8;
        font-size: 72px;
    }

    .video-placeholder strong {
        color: var(--text);
        font-size: 24px;
    }

    .video-placeholder span {
        color: var(--muted);
    }

    .demo-access {
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid var(--border);
    }

    .faq-list {
        display: grid;
        gap: 12px;
    }

    .faq-list details {
        border: 1px solid rgba(148, 163, 184, .20);
        border-radius: 14px;
        background: rgba(2, 6, 23, .30);
        padding: 16px 18px;
    }

    .faq-list summary {
        color: var(--text);
        cursor: pointer;
        font-weight: 900;
    }

    @@media(max-width: 1050px) {
        .public-hero,
        .feature-grid,
        .pricing-table,
        .platform-grid,
        .support-grid,
        .faq-grid,
        .demo-layout,
        .value-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width: 640px) {
        .public-hero > div:first-child,
        .feature-card,
        .price-card,
        .platform-card,
        .section-block,
        .video-placeholder {
            padding: 20px;
        }

        .public-hero h1 {
            font-size: 34px;
        }
    }
</style>
