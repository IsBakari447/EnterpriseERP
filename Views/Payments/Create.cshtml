@model EnterpriseERP.Models.Payment

@{
    ViewData["Title"] = "Ajouter un paiement";
    var invoices = ViewBag.Invoices as List<EnterpriseERP.Models.Invoice>;
}

<div class="page-header">
    <div>
        <h1>Ajouter un paiement</h1>
        <p>Associer un paiement à une facture</p>
    </div>

    <a href="/Payments/Index" class="btn-secondary">
        ← Retour
    </a>
</div>

<div class="form-card">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">@ViewBag.Error</div>
    }

    <form method="post" action="/Payments/Create">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Facture</label>
            <select name="InvoiceId" required>
                <option value="">-- Sélectionner une facture --</option>

                @if (invoices != null)
                {
                    foreach (var invoice in invoices)
                    {
                        <option value="@invoice.Id">
                            Facture #@invoice.Id — @invoice.Client?.FullName — @invoice.TotalAmount € — @invoice.Status
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <label>Montant payé</label>
            <input name="Amount" type="number" step="0.01" min="1" required />
        </div>

        <div class="form-group">
            <label>Méthode de paiement</label>
            <select name="Method">
                <option value="Cash">Espèces</option>
                <option value="Card">Carte bancaire</option>
                <option value="Bank Transfer">Virement bancaire</option>
                <option value="Swish">Swish</option>
                <option value="Mobile Money">Mobile Money</option>
            </select>
        </div>

        <div class="form-group">
            <label>Référence</label>
            <input name="Reference" placeholder="Ex: transaction, reçu, numéro..." />
        </div>

        <button type="submit" class="btn-primary">
            Enregistrer le paiement
        </button>
    </form>
</div>
