@model List<EnterpriseERP.Models.StockMovement>
@inject EnterpriseERP.Services.TranslationService T

@{
    ViewData["Title"] = T.T("Stock");
}

<div class="page-header">
    <div>
        <h1>@T.T("Stock")</h1>
        <p>@T.T("StockDescription")</p>
    </div>

    <a href="/Stock/Movement" class="btn-primary">
        @T.T("AddStockMovement")
    </a>
</div>

<div class="panel">
    <h2>@T.T("StockMovementHistory")</h2>

    @if (Model != null && Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>@T.T("Product")</th>
                    <th>Type</th>
                    <th>@T.T("Quantity")</th>
                    <th>@T.T("Date")</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var movement in Model)
                {
                    <tr>
                        <td>@movement.Product?.Name</td>
                        <td>@movement.Type</td>
                        <td>@movement.Quantity</td>
                        <td>@movement.Date.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty">@T.T("NoStockMovements")</p>
    }
</div>
