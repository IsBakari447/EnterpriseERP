@model EnterpriseERP.Models.StockMovement

@{
    ViewData["Title"] = "Mouvement de stock";
    var products = ViewBag.Products as List<EnterpriseERP.Models.Product>;
}

<div class="page-header">
    <div>
        <h1>Mouvement de stock</h1>
        <p>Ajouter une entrée ou une sortie de stock</p>
    </div>

    <a href="/Stock/Index" class="btn-secondary">
        ← Retour
    </a>
</div>

<div class="form-card">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">@ViewBag.Error</div>
    }

    <form method="post" action="/Stock/Movement">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Produit</label>
            <select name="ProductId" required>
                <option value="">-- Sélectionner un produit --</option>

                @if (products != null)
                {
                    foreach (var product in products)
                    {
                        <option value="@product.Id">
                            @product.Name - stock actuel : @product.Quantity
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <label>Type de mouvement</label>
            <select name="Type" required>
                <option value="IN">Entrée</option>
                <option value="OUT">Sortie</option>
            </select>
        </div>

        <div class="form-group">
            <label>Quantité</label>
            <input name="Quantity" type="number" min="1" required />
        </div>

        <button type="submit" class="btn-primary">
            Enregistrer
        </button>
    </form>
</div>
