@model EnterpriseERP.Models.StockMovement
@inject EnterpriseERP.Services.TranslationService T

@{
    ViewData["Title"] = T.T("StockMovement");
    var products = ViewBag.Products as List<EnterpriseERP.Models.Product>;
}

<div class="page-header">
    <div>
        <h1>@T.T("StockMovement")</h1>
        <p>@T.T("StockMovementDescription")</p>
    </div>

    <a href="/Stock/Index" class="btn-secondary">
        &larr; @T.T("Back")
    </a>
</div>

<div class="form-card">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">@ViewBag.Error</div>
    }

    <form method="post" action="/Stock/Movement">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>@T.T("Product")</label>
            <select name="ProductId" required>
                <option value="">@T.T("SelectProduct")</option>

                @if (products != null)
                {
                    foreach (var product in products)
                    {
                        <option value="@product.Id">
                            @product.Name - @T.T("CurrentStock") : @product.Quantity
                        </option>
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <label>@T.T("MovementType")</label>
            <select name="Type" required>
                <option value="IN">@T.T("StockIn")</option>
                <option value="OUT">@T.T("StockOut")</option>
            </select>
        </div>

        <div class="form-group">
            <label>@T.T("Quantity")</label>
            <input name="Quantity" type="number" min="1" required />
        </div>

        <button type="submit" class="btn-primary">
            @T.T("Save")
        </button>
    </form>
</div>
