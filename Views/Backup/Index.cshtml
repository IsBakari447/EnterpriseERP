@inject EnterpriseERP.Services.TranslationService T
@model List<System.IO.FileInfo>

@{
    ViewData["Title"] = T.T("BackupCenter");
}

<div class="page-header">
    <div>
        <h1>@T.T("BackupCenter")</h1>
        <p>@T.T("BackupDescription")</p>
    </div>

    <a href="/Admin/Index" class="btn-secondary">
        &larr; @T.T("BackToAdminCenter")
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-danger">@TempData["Error"]</div>
}

<div class="panel">
    <h2>@T.T("CreateBackup")</h2>
    <p>@T.T("CreateBackupDescription")</p>

    <form method="post" action="/Backup/Create">
        @Html.AntiForgeryToken()

        <button type="submit" class="btn-primary">
            @T.T("CreateBackupNow")
        </button>
    </form>
</div>

<div class="panel" style="margin-top:20px;">
    <h2>@T.T("AvailableBackups")</h2>

    @if (Model != null && Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>@T.T("File")</th>
                    <th>@T.T("Date")</th>
                    <th>@T.T("Size")</th>
                    <th>@T.T("Actions")</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var backup in Model)
                {
                    <tr>
                        <td>@backup.Name</td>
                        <td>@backup.CreationTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@Math.Round(backup.Length / 1024.0, 2) KB</td>
                        <td>
                            <a href="/Backup/Download?file=@backup.Name" class="btn-secondary">
                                @T.T("Download")
                            </a>

                            <form method="post"
                                  action="/Backup/Delete"
                                  style="display:inline;"
                                  onsubmit="return confirm('@T.T("ConfirmDeleteBackup")');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="file" value="@backup.Name" />
                                <button type="submit" class="btn-danger">
                                    @T.T("Delete")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty">@T.T("NoBackups")</p>
    }
</div>
