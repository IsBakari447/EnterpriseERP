@model EnterpriseERP.Models.Invoice
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>Facture @Model.InvoiceNumber</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <style>
        body {
            padding: 40px;
            font-family: Arial, sans-serif;
            background: #f8f9fa;
        }

        .invoice-box {
            background: white;
            padding: 30px;
            border-radius: 10px;
            border: 1px solid #ddd;
            max-width: 900px;
            margin: auto;
        }

        h2 {
            font-weight: 700;
            margin-bottom: 20px;
        }

        .table th {
            background: #f1f1f1;
        }

        .total-box {
            font-size: 1.3rem;
            font-weight: bold;
            text-align: right;
            margin-top: 20px;
        }

       @@media print {
            .no-print {
                display: none !important;
            }
            body {
                background: white;
                padding: 0;
            }
            .invoice-box {
                border: none;
                box-shadow: none;
            }
        }
    </style>
</head>

<body>

<div class="invoice-box">

    <h2>Facture @Model.InvoiceNumber</h2>

    <p><strong>Date :</strong> @Model.InvoiceDate.ToString("dd/MM/yyyy")</p>

    <hr />

    <h4>Client</h4>
    <p>
        <strong>@(Model.Client?.FullName ?? "Client non renseigne")</strong><br />
        @(Model.Client?.Email ?? "")<br />
        @(Model.Client?.Phone ?? "")<br />
        @(Model.Client?.Address ?? "")
    </p>

    <hr />

    <h4>Détails de la facture</h4>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Description</th>
                <th>Quantité</th>
                <th>Prix</th>
                <th>TVA</th>
                <th>Total TTC</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice €</td>
                    <td>@item.VatAmount €</td>
                    <td>@item.TotalTTC €</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="total-box">
        Total : @Model.TotalAmount €  
    </div>

    <div class="no-print mt-4">
        <button class="btn btn-primary" onclick="window.print()">Imprimer</button>
        <a href="/Invoices/Details/@Model.Id" class="btn btn-secondary">Retour</a>
    </div>

</div>

</body>
</html>
