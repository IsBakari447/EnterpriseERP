@inject EnterpriseERP.Services.TranslationService T
@model List<EnterpriseERP.Models.Invoice>

@{
    ViewData["Title"] = T.T("Invoices");
}

<div class="page-header">
    <div>
        <h1>@T.T("Invoices")</h1>
        <p>@T.T("InvoicesDescription")</p>
    </div>

    <a asp-controller="Invoices"
       asp-action="Create"
       class="btn-primary">
        @T.T("AddInvoice")
    </a>
</div>

<div class="panel">

    <div class="panel-header">
        <h2>@T.T("InvoicesList")</h2>
        <span class="badge">@((Model ?? new()).Count) @T.T("RegisteredInvoices")</span>
    </div>

    @if (Model != null && Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>@T.T("Number")</th>
                    <th>@T.T("Client")</th>
                    <th>@T.T("Date")</th>
                    <th>@T.T("Total")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("Actions")</th>
                </tr>
            </thead>

            <tbody>
            @foreach (var invoice in Model)
            {
                <tr>
                    <td><strong>#@invoice.Id</strong></td>
                    <td>@invoice.Client?.FullName</td>
                    <td>@invoice.InvoiceDate.ToString("dd/MM/yyyy")</td>
                    <td>@invoice.TotalAmount.ToString("N2") €</td>

                    <td>
                        @if (invoice.Status == "Paid")
                        {
                            <span class="status-badge success">@T.T("Paid")</span>
                        }
                        else if (invoice.Status == "Pending")
                        {
                            <span class="status-badge warning">@T.T("Pending")</span>
                        }
                        else
                        {
                            <span class="status-badge danger">@T.T("Unpaid")</span>
                        }
                    </td>

                    <td>
                        <a asp-controller="Invoices"
                           asp-action="Details"
                           asp-route-id="@invoice.Id"
                           class="btn-secondary">
                            @T.T("Details")
                        </a>

                        <a asp-controller="Invoices"
                           asp-action="Print"
                           asp-route-id="@invoice.Id"
                           class="btn-secondary">
                            @T.T("Preview")
                        </a>

                        <a asp-controller="Invoices"
                           asp-action="DownloadPdf"
                           asp-route-id="@invoice.Id"
                           class="btn-primary">
                            📄 PDF
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">🧾</div>
            <h3>@T.T("NoInvoices")</h3>
            <p>@T.T("NoInvoicesText")</p>
            <a asp-controller="Invoices" asp-action="Create" class="btn-primary">
                @T.T("AddFirstInvoice")
            </a>
        </div>
    }
</div>
