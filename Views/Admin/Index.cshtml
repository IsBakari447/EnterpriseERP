@{
    ViewData["Title"] = "Centre d'administration";
}

<div class="page-header">
    <div>
        <h1>Centre d'administration</h1>
        <p>Gestion centrale de la securite, des roles, des utilisateurs et des parametres ERP.</p>
    </div>

    <a href="/Dashboard" class="btn-secondary">Retour dashboard</a>
</div>

<div class="stats-grid">
    <div class="stat-card"><div class="stat-icon">USR</div><div><h3>@ViewBag.UsersCount</h3><p>Utilisateurs</p></div></div>
    <div class="stat-card"><div class="stat-icon">ACT</div><div><h3>@ViewBag.ActiveUsers</h3><p>Comptes actifs</p></div></div>
    <div class="stat-card warning"><div class="stat-icon">SEC</div><div><h3>@ViewBag.SecurityWarnings</h3><p>Alertes securite</p></div></div>
    <div class="stat-card"><div class="stat-icon">KEY</div><div><h3>@ViewBag.PermissionsCount</h3><p>Permissions</p></div></div>
</div>

<div class="dashboard-grid">
    <div class="panel">
        <h2>Gestion des utilisateurs</h2>
        <p>Creer, activer, desactiver et controler les comptes utilisateurs.</p>
        <a href="/Account/Register" class="btn-primary">Creer utilisateur</a>
        <a href="/Users/Index" class="btn-secondary">Utilisateurs</a>
    </div>

    <div class="panel">
        <h2>Roles et permissions</h2>
        <p>Definir les droits d'acces par role : Admin, Manager, Employee.</p>
        <a href="/Roles/Index" class="btn-primary">Gerer les permissions</a>
    </div>

    <div class="panel">
        <h2>Journal d'audit</h2>
        <p>Consulter toutes les actions importantes effectuees dans l'ERP.</p>
        <a href="/Audit/Index" class="btn-primary">Ouvrir l'audit</a>
    </div>

    <div class="panel">
        <h2>Parametres systeme</h2>
        <p>Configurer la societe, TVA, seuil de stock, devise et preferences.</p>
        <a href="/Settings/Index" class="btn-primary">Parametres</a>
    </div>

    <div class="panel">
        <h2>Notifications</h2>
        <p>Surveiller les alertes importantes : stock, factures, commandes et utilisateurs.</p>
        <a href="/Notifications/Index" class="btn-primary">Notifications</a>
    </div>

    <div class="panel">
        <h2>Core Platform</h2>
        <p>Verifier les fonctionnalites SaaS, automatisations, imports et integrations tierces.</p>
        <a href="/CorePlatform/Index" class="btn-primary">Ouvrir Core Platform</a>
    </div>

    <div class="panel">
        <h2>Exports et rapports</h2>
        <p>Exporter les donnees de l'entreprise vers Excel et consulter les indicateurs.</p>
        <a href="/Exports/Index" class="btn-primary">Exports Excel</a>
        <a href="/Analytics/Index" class="btn-secondary">Analytics</a>
    </div>

    <div class="panel">
        <h2>Backup Center</h2>
        <p>Creer, telecharger et supprimer les sauvegardes de la base SQLite.</p>
        <a href="/Backup/Index" class="btn-primary">Ouvrir Backup Center</a>
    </div>

    <div class="panel">
        <h2>Security Center</h2>
        <p>Surveiller les connexions, acces refuses et evenements sensibles.</p>
        <a href="/Security/Index" class="btn-primary">Ouvrir Security Center</a>
    </div>
</div>
