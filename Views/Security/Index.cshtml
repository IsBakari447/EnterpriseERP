@{
    ViewData["Title"] = "Security Center";

    var accessDeniedLogs = ViewBag.AccessDeniedLogs as List<EnterpriseERP.Models.AuditLog>;
    var loginLogs = ViewBag.LoginLogs as List<EnterpriseERP.Models.AuditLog>;
    var warningLogs = ViewBag.WarningLogs as List<EnterpriseERP.Models.AuditLog>;
    var recentSecurityEvents = ViewBag.RecentSecurityEvents as List<EnterpriseERP.Models.AuditLog>;
}

<div class="page-header">
    <div>
        <h1>Security Center</h1>
        <p>Surveillance des accès, utilisateurs, alertes et événements de sécurité</p>
    </div>

    <a href="/Admin/Index" class="btn-secondary">
        ← Retour Admin Center
    </a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div>
            <h3>@ViewBag.TotalUsers</h3>
            <p>Utilisateurs</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div>
            <h3>@ViewBag.ActiveUsers</h3>
            <p>Comptes actifs</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">⛔</div>
        <div>
            <h3>@ViewBag.AccessDeniedLogs?.Count</h3>
            <p>Accès refusés récents</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon">👑</div>
        <div>
            <h3>@ViewBag.SuperAdmins</h3>
            <p>SuperAdmins</p>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="panel">
        <h2>🛡️ Accès rapides sécurité</h2>

        <div class="dashboard-grid">
            <a href="/Audit/Index" class="btn-primary">Audit Center</a>
            <a href="/Roles/Index" class="btn-secondary">Rôles & Permissions</a>
            <a href="/Account/Register" class="btn-secondary">Créer utilisateur</a>
            <a href="/Settings/Index" class="btn-secondary">Paramètres sécurité</a>
        </div>
    </div>

    <div class="panel">
        <h2>📊 Résumé utilisateurs</h2>

        <table>
            <tr><th>Utilisateurs actifs</th><td>@ViewBag.ActiveUsers</td></tr>
            <tr><th>Utilisateurs inactifs</th><td>@ViewBag.InactiveUsers</td></tr>
            <tr><th>Comptes non approuvés</th><td>@ViewBag.PendingUsers</td></tr>
            <tr><th>SuperAdmins</th><td>@ViewBag.SuperAdmins</td></tr>
        </table>
    </div>
</div>

<div class="dashboard-grid">
    <div class="panel">
        <h2>⛔ Derniers accès refusés</h2>

        @if (accessDeniedLogs != null && accessDeniedLogs.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Utilisateur</th>
                        <th>Description</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in accessDeniedLogs)
                    {
                        <tr>
                            <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@log.UserName</td>
                            <td>@log.Description</td>
                            <td>@log.IpAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="empty">Aucun accès refusé récent.</p>
        }
    </div>

    <div class="panel">
        <h2>🔑 Dernières connexions</h2>

        @if (loginLogs != null && loginLogs.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Utilisateur</th>
                        <th>IP</th>
                        <th>Navigateur</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in loginLogs)
                    {
                        <tr>
                            <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@log.UserName</td>
                            <td>@log.IpAddress</td>
                            <td>@log.Browser</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="empty">Aucune connexion enregistrée.</p>
        }
    </div>
</div>

<div class="panel">
    <h2>⚠️ Alertes de sécurité</h2>

    @if (warningLogs != null && warningLogs.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Module</th>
                    <th>Action</th>
                    <th>Utilisateur</th>
                    <th>Gravité</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in warningLogs)
                {
                    <tr>
                        <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@log.Module</td>
                        <td>@log.Action</td>
                        <td>@log.UserName</td>
                        <td>@log.Severity</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty">Aucune alerte de sécurité.</p>
    }
</div>

<div class="panel">
    <h2>📜 Événements sécurité récents</h2>

    @if (recentSecurityEvents != null && recentSecurityEvents.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Module</th>
                    <th>Action</th>
                    <th>Description</th>
                    <th>Succès</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in recentSecurityEvents)
                {
                    <tr>
                        <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@log.Module</td>
                        <td>@log.Action</td>
                        <td>@log.Description</td>
                        <td>@(log.Success ? "Oui" : "Non")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="empty">Aucun événement de sécurité récent.</p>
    }
</div>