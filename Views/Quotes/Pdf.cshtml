@model EnterpriseERP.Models.Quote

@{
    Layout = null;
    var client = Model.Client;
    var generatedAt = DateTime.Now;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>Devis @Model.QuoteNumber</title>

    <style>
        @@page {
            size: A4;
            margin: 14mm;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #111827;
            background: #ffffff;
            margin: 0;
            padding: 0;
            font-size: 13px;
        }

        .document {
            width: 100%;
            max-width: 210mm;
            margin: 0 auto;
            background: #ffffff;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 4px solid #2563eb;
            padding-bottom: 18px;
            margin-bottom: 28px;
        }

        .brand {
            display: flex;
            gap: 14px;
            align-items: center;
        }

        .logo {
            width: 58px;
            height: 58px;
            border-radius: 16px;
            background: linear-gradient(135deg, #2563eb, #38bdf8);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: bold;
        }

        .brand h1 {
            margin: 0;
            font-size: 30px;
            color: #0f172a;
        }

        .brand p {
            margin: 4px 0;
            color: #64748b;
            font-size: 14px;
        }

        .slogan {
            color: #2563eb;
            font-weight: bold;
            font-style: italic;
            margin-top: 8px;
        }

        .company-info {
            text-align: right;
            font-size: 13px;
            line-height: 1.7;
            color: #334155;
        }

        .doc-title {
            display: flex;
            justify-content: space-between;
            gap: 30px;
            margin-bottom: 24px;
        }

        .doc-title h2 {
            font-size: 38px;
            margin: 0;
            color: #0f172a;
            letter-spacing: 1px;
        }

        .doc-number {
            color: #2563eb;
            font-size: 20px;
            margin-top: 6px;
            font-weight: bold;
        }

        .meta {
            min-width: 310px;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 9px;
        }

        .meta-row span:first-child {
            font-weight: bold;
            color: #0f172a;
        }

        .status {
            display: inline-block;
            background: #2563eb;
            color: white;
            padding: 4px 9px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 12px;
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 22px;
            margin-bottom: 22px;
        }

        .box {
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 16px;
            min-height: 125px;
        }

        .box h3 {
            margin: 0 0 12px;
            font-size: 16px;
            color: #2563eb;
        }

        .box p {
            margin: 6px 0;
            color: #334155;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
        }

        .items-table th {
            background: #2563eb;
            color: white;
            padding: 11px;
            text-align: left;
            font-size: 12px;
            border: 1px solid #2563eb;
        }

        .items-table td {
            border: 1px solid #cbd5e1;
            padding: 10px;
            font-size: 12px;
            color: #111827;
        }

        .items-table tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .text-end {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        .summary {
            width: 360px;
            margin-left: auto;
            margin-top: 18px;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            overflow: hidden;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 11px 15px;
            border-bottom: 1px solid #e5e7eb;
        }

        .summary-total {
            background: #2563eb;
            color: white;
            font-size: 19px;
            font-weight: bold;
            border-bottom: none;
        }

        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
            margin-top: 32px;
        }

        .notes h3,
        .terms h3 {
            color: #2563eb;
            margin: 0 0 10px;
        }

        .notes p,
        .terms li {
            color: #334155;
            line-height: 1.6;
        }

        .terms ol {
            padding-left: 18px;
            margin: 0;
        }

        .signature-box {
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 16px;
            min-height: 180px;
        }

        .signature-line {
            margin-top: 55px;
            border-top: 1px solid #111827;
            padding-top: 8px;
        }

        .thank-you {
            margin-top: 34px;
            padding: 18px;
            text-align: center;
            border-top: 2px solid #2563eb;
            border-bottom: 2px solid #2563eb;
            color: #334155;
        }

        .thank-you strong {
            display: block;
            color: #2563eb;
            font-size: 18px;
            margin-bottom: 6px;
        }

        .footer {
            margin-top: 20px;
            padding: 15px 0;
            display: flex;
            justify-content: space-between;
            gap: 15px;
            color: #475569;
            font-size: 12px;
            border-bottom: 14px solid #0f172a;
        }

        .footer strong {
            color: #0f172a;
        }

        .no-print {
            margin-bottom: 20px;
            text-align: right;
        }

        .print-btn {
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            cursor: pointer;
            font-weight: bold;
        }

        @@media print {
            body {
                padding: 0;
            }

            .no-print {
                display: none !important;
            }

            .document {
                max-width: none;
                width: 100%;
            }

            .box,
            .signature-box,
            .summary {
                break-inside: avoid;
            }
        }
    </style>
</head>

<body>
    <div class="no-print">
        <button class="print-btn" onclick="window.print()">Télécharger / Imprimer PDF</button>
    </div>

    <main class="document">

        <header class="header">
            <div class="brand">
                <div class="logo">ERP</div>

                <div>
                    <h1>EnterpriseERP</h1>
                    <p>Business Management Suite</p>
                    <div class="slogan">Votre succès, notre priorité.</div>
                </div>
            </div>

            <div class="company-info">
                <strong>EnterpriseERP AB</strong><br />
                Stockholm, Suède<br />
                Téléphone : +46 70 736 45 55<br />
                Email : bakarii447@gmail.com<br />
                Site web : www.enterpriseerp.com
            </div>
        </header>

        <section class="doc-title">
            <div>
                <h2>DEVIS</h2>
                <div class="doc-number">N° @Model.QuoteNumber</div>
            </div>

            <div class="meta">
                <div class="meta-row">
                    <span>Date du devis</span>
                    <span>@Model.QuoteDate.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="meta-row">
                    <span>Valable jusqu'au</span>
                    <span>@Model.ValidUntil.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="meta-row">
                    <span>Statut</span>
                    <span class="status">@Model.Status</span>
                </div>

                <div class="meta-row">
                    <span>Conditions</span>
                    <span>@(Model.PaymentTerms ?? "-")</span>
                </div>
            </div>
        </section>

        <section class="grid">
            <div class="box">
                <h3>Client</h3>
                <p><strong>@(client?.CompanyName ?? "-")</strong></p>
                <p>@(client?.FullName ?? "-")</p>
                <p>@(client?.Email ?? "-")</p>
                <p>@(client?.Phone ?? "-")</p>
            </div>

            <div class="box">
                <h3>Informations</h3>
                <p><strong>Préparé par :</strong> @(Model.CreatedBy ?? "EnterpriseERP")</p>
                <p><strong>Date de création :</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Document généré :</strong> @generatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </section>

        <table class="items-table">
            <thead>
                <tr>
                    <th class="text-center">#</th>
                    <th>Produit</th>
                    <th class="text-center">Qté</th>
                    <th class="text-end">Prix unitaire</th>
                    <th class="text-end">Remise</th>
                    <th class="text-end">TVA</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>

            <tbody>
                @{
                    var index = 1;
                }

                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-center">@index</td>
                        <td>@(item.Product?.Name ?? "-")</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.UnitPrice.ToString("N2") €</td>
                        <td class="text-end">@item.DiscountAmount.ToString("N2") €</td>
                        <td class="text-end">@item.TaxAmount.ToString("N2") €</td>
                        <td class="text-end"><strong>@item.LineTotal.ToString("N2") €</strong></td>
                    </tr>

                    index++;
                }
            </tbody>
        </table>

        <section class="summary">
            <div class="summary-row">
                <span>Sous-total HT</span>
                <strong>@Model.SubTotal.ToString("N2") €</strong>
            </div>

            <div class="summary-row">
                <span>Remise</span>
                <strong>@Model.DiscountAmount.ToString("N2") €</strong>
            </div>

            <div class="summary-row">
                <span>TVA</span>
                <strong>@Model.TaxAmount.ToString("N2") €</strong>
            </div>

            <div class="summary-row summary-total">
                <span>Total TTC</span>
                <strong>@Model.TotalAmount.ToString("N2") €</strong>
            </div>
        </section>

        <section class="bottom-grid">
            <div>
                <div class="notes">
                    <h3>Notes</h3>
                    <p>
                        @(string.IsNullOrWhiteSpace(Model.Notes)
                            ? "Merci pour votre confiance. Ce devis reprend les produits et services mentionnés ci-dessus."
                            : Model.Notes)
                    </p>
                </div>

                <div class="terms">
                    <h3>Conditions générales</h3>
                    <ol>
                        <li>Les prix sont exprimés en euros.</li>
                        <li>Ce devis est valable jusqu'à la date indiquée.</li>
                        <li>Le paiement est soumis aux conditions mentionnées.</li>
                        <li>Tout retard de paiement peut entraîner des pénalités.</li>
                    </ol>
                </div>
            </div>

            <div class="signature-box">
                <strong>Cachet et signature du client</strong>

                <div class="signature-line">
                    Signature
                </div>

                <p>Date : ____ / ____ / ______</p>
            </div>
        </section>

        <section class="thank-you">
            <strong>Merci pour votre confiance.</strong>
            Nous restons à votre disposition pour vous accompagner.
        </section>

        <footer class="footer">
            <div>
                <strong>EnterpriseERP AB</strong><br />
                Stockholm, Suède
            </div>

            <div>
                Téléphone<br />
                +46 70 736 45 55
            </div>

            <div>
                Email<br />
                bakarii447@gmail.com
            </div>

            <div>
                Site web<br />
                www.enterpriseerp.com
            </div>
        </footer>

    </main>
</body>
</html>